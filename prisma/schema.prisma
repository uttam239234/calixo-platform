// ============================================================================
// CALIXO PLATFORM - Enterprise Database Schema
// ============================================================================
// Version: 1.0.0
// Target: PostgreSQL + Prisma ORM
// Architecture: Multi-tenant SaaS with soft delete, audit trails, UUIDs
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
  CUSTOM
}

enum PlanTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
  AGENCY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  TRIALING
  INCOMPLETE
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
  ARCHIVED
}

enum AdPlatform {
  GOOGLE
  META
  LINKEDIN
  TIKTOK
  TWITTER
  PINTEREST
  SNAPCHAT
}

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  TWITTER
  LINKEDIN
  TIKTOK
  YOUTUBE
  PINTEREST
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

enum MentionSource {
  SOCIAL
  NEWS
  REVIEW
  FORUM
  BLOG
  PODCAST
  VIDEO
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  MIXED
}

enum NotificationType {
  CAMPAIGN_STARTED
  CAMPAIGN_ENDED
  BUDGET_ALERT
  AI_INSIGHT
  TEAM_UPDATE
  SYSTEM
  BILLING
  MILESTONE
}

enum NotificationSeverity {
  CRITICAL
  WARNING
  INFO
  SUCCESS
}

enum IntegrationProvider {
  GOOGLE_ADS
  META_ADS
  LINKEDIN_ADS
  GOOGLE_ANALYTICS
  SALESFORCE
  HUBSPOT
  SLACK
  SHOPIFY
  ZAPIER
  CUSTOM
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  EXPIRED
  PENDING
}

enum ReportType {
  PERFORMANCE
  ANALYTICS
  CAMPAIGN
  SOCIAL
  CUSTOM
  SCHEDULED
}

enum ReportFormat {
  PDF
  CSV
  EXCEL
  HTML
}

enum WorkflowStatus {
  ACTIVE
  PAUSED
  DRAFT
  ARCHIVED
  ERROR
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
  SKIPPED
}

enum AutomationTriggerType {
  SCHEDULE
  EVENT
  WEBHOOK
  CONDITION
}

enum AIModel {
  GPT_4O
  GPT_4O_MINI
  CLAUDE_3_SONNET
  CLAUDE_3_HAIKU
  EMBEDDING_3_LARGE
  DALL_E_3
  WHISPER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Currency {
  USD
  EUR
  GBP
  JPY
  CAD
  AUD
  INR
  BRL
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ============================================================================
// BASE - Abstract fields applied via generator or manually
// NOTE: Prisma doesn't support model inheritance. Use comments as template.
// Every model should include:
//   id          String   @id @default(uuid()) @db.Uuid
//   createdAt   DateTime @default(now())
//   updatedAt   DateTime @updatedAt
//   createdBy   String?  @db.Uuid
//   updatedBy   String?  @db.Uuid
//   organizationId String? @db.Uuid
//   workspaceId String?   @db.Uuid
//   isDeleted   Boolean  @default(false)
//   deletedAt   DateTime?
//   metadata    Json?
// ============================================================================

// ============================================================================
// IDENTITY & AUTH
// ============================================================================

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  emailVerified Boolean   @default(false)
  name          String    @db.VarChar(255)
  avatar        String?   @db.VarChar(512)
  passwordHash  String?   @db.VarChar(512)
  phone         String?   @db.VarChar(50)
  locale        String    @default("en-US") @db.VarChar(10)
  timezone      String    @default("UTC") @db.VarChar(50)
  lastLoginAt   DateTime?
  isActive      Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  sessions            Session[]
  refreshTokens       RefreshToken[]
  apiKeys             ApiKey[]
  memberships         OrganizationMember[]
  teamMemberships     TeamMember[]
  createdInvitations  Invitation[]         @relation("InvitedBy")
  campaigns           Campaign[]           @relation("CampaignCreator")
  socialPosts         SocialPost[]
  conversations       AIConversation[]
  messages            AIMessage[]
  notifications       Notification[]
  activities          Activity[]
  auditLogs           AuditLog[]
  usageRecords        Usage[]
  executions          WorkflowExecution[]
  preferences         UserPreference?
  userRoleAssignments UserRoleAssignment[]

  @@index([email])
  @@index([isActive, isDeleted])
  @@map("users")
}

model UserPreference {
  id                      String   @id @default(uuid()) @db.Uuid
  userId                  String   @unique @db.Uuid
  theme                   String   @default("light") @db.VarChar(20)
  sidebarCollapsed        Boolean  @default(false)
  emailNotifications      Boolean  @default(true)
  pushNotifications       Boolean  @default(true)
  inAppNotifications      Boolean  @default(true)
  digestFrequency         String   @default("never") @db.VarChar(20)
  dashboardLayout         Json?
  notificationPreferences Json?
  metadata                Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Session {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  token      String   @unique @db.VarChar(512)
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.VarChar(512)
  deviceInfo Json?
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique @db.VarChar(512)
  familyId  String?  @db.VarChar(128)
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([familyId])
  @@map("refresh_tokens")
}

model ApiKey {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String?   @db.Uuid
  userId         String    @db.Uuid
  name           String    @db.VarChar(255)
  key            String    @unique @db.VarChar(512)
  keyPrefix      String    @db.VarChar(20)
  scopes         String[]  @default([])
  permissions    String[]  @default([])
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@index([keyPrefix])
  @@map("api_keys")
}

// ============================================================================
// ORGANIZATION & MULTI-TENANCY
// ============================================================================

model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  slug      String    @unique @db.VarChar(255)
  plan      PlanTier  @default(FREE)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  relations           OrganizationRelation?
  members             OrganizationMember[]
  workspaces          Workspace[]
  invitations         Invitation[]
  apiKeys             ApiKey[]
  billing             Subscription?
  campaigns           Campaign[]
  socialAccounts      SocialAccount[]
  brands              Brand[]
  competitors         BrandMonitoringCompetitor[]
  integrations        Integration[]
  oauthTokens         OAuthToken[]
  aiConversations     AIConversation[]
  aiUsage             AIUsage[]
  workflows           Workflow[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  featureOverrides    OrganizationFeatureOverride[]
  usageRecords        Usage[]
  reports             Report[]
  dashboardWidgets    DashboardWidget[]
  metrics             Metric[]
  creativeFiles       Creative[]
  keywordGroups       Keyword[]
  audiences           Audience[]
  campaignGroups      CampaignGroup[]
  budgetRecords       Budget[]
  userRoleAssignments UserRoleAssignment[]
  kpis                Kpi[]

  @@index([slug])
  @@index([plan])
  @@index([isDeleted])
  @@map("organizations")
}

model OrganizationRelation {
  organizationId String   @id @unique @db.Uuid
  ownerId        String   @db.Uuid
  billingEmail   String?  @db.VarChar(255)
  taxId          String?  @db.VarChar(100)
  website        String?  @db.VarChar(512)
  industry       String?  @db.VarChar(100)
  size           String?  @db.VarChar(50)
  phone          String?  @db.VarChar(50)
  address        Json?
  branding       Json?
  security       Json?
  settings       Json?
  featureFlags   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_relations")
}

model OrganizationMember {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  userId         String   @db.Uuid
  role           UserRole @default(VIEWER)
  joinedAt       DateTime @default(now())
  isActive       Boolean  @default(true)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

model Workspace {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  name           String    @db.VarChar(255)
  slug           String    @db.VarChar(255)
  description    String?   @db.VarChar(1024)
  type           String    @default("team") @db.VarChar(50)
  settings       Json?
  isDefault      Boolean   @default(false)
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teams            Team[]
  campaigns        Campaign[]
  socialPosts      SocialPost[]
  reports          Report[]
  conversations    AIConversation[]
  notifications    Notification[]
  tasks            Task[]
  dashboardWidgets DashboardWidget[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([isDeleted])
  @@map("workspaces")
}

model Team {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  name        String    @db.VarChar(255)
  description String?   @db.VarChar(1024)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   TeamMember[]

  @@index([workspaceId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @db.Uuid
  userId    String   @db.Uuid
  role      UserRole @default(EDITOR)
  joinedAt  DateTime @default(now())
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}

model Invitation {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  invitedById    String    @db.Uuid
  email          String    @db.VarChar(255)
  role           UserRole  @default(VIEWER)
  token          String    @unique @db.VarChar(512)
  expiresAt      DateTime
  acceptedAt     DateTime?
  declinedAt     DateTime?
  revokedAt      DateTime?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([organizationId])
  @@index([email])
  @@index([token])
  @@map("invitations")
}

// ============================================================================
// SECURITY - RBAC
// ============================================================================

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(100)
  description String?   @db.VarChar(512)
  isSystem    Boolean   @default(false)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  permissions RolePermission[]
  userRoles   UserRoleAssignment[]

  @@unique([name])
  @@index([isSystem])
  @@map("roles")
}

model Permission {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique @db.VarChar(150)
  description String?   @db.VarChar(512)
  module      String    @db.VarChar(100)
  action      String    @db.VarChar(100)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  roles RolePermission[]

  @@index([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String  @id @default(uuid()) @db.Uuid
  roleId       String  @db.Uuid
  permissionId String  @db.Uuid
  isDenied     Boolean @default(false)
  conditions   Json?

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  roleId         String    @db.Uuid
  organizationId String?   @db.Uuid
  workspaceId    String?   @db.Uuid
  grantedBy      String?   @db.Uuid
  grantedAt      DateTime  @default(now())
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@unique([userId, roleId, organizationId, workspaceId])
  @@index([userId])
  @@index([roleId])
  @@map("user_role_assignments")
}

// ============================================================================
// MARKETING - CAMPAIGNS
// ============================================================================

model CampaignGroup {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid
  name           String         @db.VarChar(255)
  description    String?        @db.VarChar(1024)
  status         CampaignStatus @default(DRAFT)
  startDate      DateTime?
  endDate        DateTime?
  isDeleted      Boolean        @default(false)
  deletedAt      DateTime?
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns    Campaign[]

  @@index([organizationId])
  @@index([status])
  @@map("campaign_groups")
}

model Campaign {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid
  workspaceId    String?        @db.Uuid
  groupId        String?        @db.Uuid
  createdBy      String         @db.Uuid
  name           String         @db.VarChar(255)
  description    String?        @db.VarChar(2048)
  platform       AdPlatform     @default(GOOGLE)
  status         CampaignStatus @default(DRAFT)
  objective      String?        @db.VarChar(255)
  startDate      DateTime?
  endDate        DateTime?
  timezone       String         @default("UTC") @db.VarChar(50)
  dailyBudget    Decimal?       @db.Decimal(12, 2)
  lifetimeBudget Decimal?       @db.Decimal(12, 2)
  currency       Currency       @default(USD)
  totalSpent     Decimal        @default(0) @db.Decimal(12, 2)
  targetAudience Json?
  targeting      Json?
  tracking       Json?
  isDeleted      Boolean        @default(false)
  deletedAt      DateTime?
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace?       @relation(fields: [workspaceId], references: [id])
  group        CampaignGroup?   @relation(fields: [groupId], references: [id])
  creator      User             @relation("CampaignCreator", fields: [createdBy], references: [id])
  creatives    Creative[]
  keywords     Keyword[]
  budgets      Budget[]
  metrics      CampaignMetric[]

  @@index([organizationId])
  @@index([workspaceId])
  @@index([groupId])
  @@index([status])
  @@index([platform])
  @@index([createdBy])
  @@index([isDeleted])
  @@map("campaigns")
}

model CampaignMetric {
  id          String   @id @default(uuid()) @db.Uuid
  campaignId  String   @unique @db.Uuid
  impressions BigInt   @default(0)
  clicks      BigInt   @default(0)
  conversions BigInt   @default(0)
  spend       Decimal  @default(0) @db.Decimal(12, 2)
  revenue     Decimal  @default(0) @db.Decimal(12, 2)
  ctr         Decimal? @db.Decimal(8, 4)
  cpc         Decimal? @db.Decimal(10, 4)
  cpm         Decimal? @db.Decimal(10, 4)
  roas        Decimal? @db.Decimal(8, 4)
  costPerConv Decimal? @db.Decimal(10, 4)
  reach       BigInt   @default(0)
  frequency   Decimal? @db.Decimal(8, 4)
  metadata    Json?
  updatedAt   DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_metrics")
}

model Audience {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  name           String    @db.VarChar(255)
  description    String?   @db.VarChar(1024)
  type           String    @db.VarChar(50)
  criteria       Json?
  size           BigInt    @default(0)
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("audiences")
}

model Creative {
  id             String    @id @default(uuid()) @db.Uuid
  campaignId     String    @db.Uuid
  organizationId String?   @db.Uuid
  name           String    @db.VarChar(255)
  type           String    @db.VarChar(50)
  headline       String?   @db.VarChar(255)
  description    String?   @db.VarChar(2048)
  url            String?   @db.VarChar(512)
  mediaUrl       String?   @db.VarChar(512)
  mediaType      String?   @db.VarChar(50)
  cta            String?   @db.VarChar(100)
  dimensions     String?   @db.VarChar(50)
  content        String?
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  campaign     Campaign?     @relation(fields: [campaignId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([campaignId])
  @@index([organizationId])
  @@map("creatives")
}

model Keyword {
  id             String    @id @default(uuid()) @db.Uuid
  campaignId     String    @db.Uuid
  organizationId String?   @db.Uuid
  text           String    @db.VarChar(255)
  matchType      String    @default("EXACT") @db.VarChar(50)
  bidAmount      Decimal?  @db.Decimal(10, 2)
  qualityScore   Int?
  isNegative     Boolean   @default(false)
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  campaign     Campaign?     @relation(fields: [campaignId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([campaignId])
  @@index([organizationId])
  @@index([text])
  @@map("keywords")
}

model Budget {
  id             String    @id @default(uuid()) @db.Uuid
  campaignId     String    @db.Uuid
  organizationId String?   @db.Uuid
  type           String    @default("DAILY") @db.VarChar(50)
  amount         Decimal   @db.Decimal(12, 2)
  spent          Decimal   @default(0) @db.Decimal(12, 2)
  currency       Currency  @default(USD)
  startDate      DateTime?
  endDate        DateTime?
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  campaign     Campaign?     @relation(fields: [campaignId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([campaignId])
  @@map("budgets")
}

// ============================================================================
// SOCIAL MEDIA
// ============================================================================

model SocialAccount {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid
  platform       SocialPlatform
  accountId      String         @db.VarChar(255)
  accountName    String         @db.VarChar(255)
  accountEmail   String?        @db.VarChar(255)
  avatarUrl      String?        @db.VarChar(512)
  profileUrl     String?        @db.VarChar(512)
  followerCount  BigInt         @default(0)
  followingCount BigInt         @default(0)
  isActive       Boolean        @default(true)
  isDeleted      Boolean        @default(false)
  deletedAt      DateTime?
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  posts         SocialPost[]
  conversations Conversation[]
  comments      Comment[]

  @@unique([organizationId, platform, accountId])
  @@index([organizationId])
  @@index([platform])
  @@map("social_accounts")
}

model SocialPost {
  id           String           @id @default(uuid()) @db.Uuid
  workspaceId  String           @db.Uuid
  accountId    String?          @db.Uuid
  createdBy    String           @db.Uuid
  content      String           @db.Text
  mediaUrls    String[]         @default([])
  platforms    SocialPlatform[]
  status       PostStatus       @default(DRAFT)
  scheduledAt  DateTime?
  publishedAt  DateTime?
  failedAt     DateTime?
  errorMessage String?          @db.VarChar(512)
  permalink    String?          @db.VarChar(512)
  isDeleted    Boolean          @default(false)
  deletedAt    DateTime?
  metadata     Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  workspace     Workspace?        @relation(fields: [workspaceId], references: [id])
  account       SocialAccount?    @relation(fields: [accountId], references: [id])
  creator       User              @relation(fields: [createdBy], references: [id])
  metrics       SocialPostMetric?
  scheduledPost ScheduledPost?

  @@index([workspaceId])
